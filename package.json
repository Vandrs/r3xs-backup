{
  "name": "r3xs-backup",
  "version": "1.0.0",
  "description": "Ferramenta CLI para backup de ROMs e save states de handhelds R36S/R35S com ArkOS",
  "main": "src/index.js",
  "bin": {
    "r3xs-backup": "./src/index.js"
  },
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src tests",
    "start": "node src/index.js"
  },
  "keywords": [
    "r36s",
    "r35s",
    "arkos",
    "backup",
    "roms",
    "save-states",
    "retro-gaming"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^11.1.0",
    "fs-extra": "^11.2.0",
    "chalk": "^4.1.2",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "eslint": "^8.56.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
